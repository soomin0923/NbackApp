<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:padding="32dp">

    <!-- 로고/제목 -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="N-Back 실험"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/subtitleText"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="24dp" />

    <!-- 부제목 -->
    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="작업 기억 능력을 측정하는 인지 실험입니다.\n\nS Pen을 사용하여 숫자를 입력해주세요.\n\n총 5개의 블록으로 구성되어 있으며,\n각 블록은 48개의 시행으로 이루어져 있습니다."
        android:textSize="20sp"
        android:textColor="#666666"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@+id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/buttonContainer"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="48dp" />

    <!-- 참가자 이름 입력 -->
    <LinearLayout
        android:id="@+id/nameInputContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#ffffff"
        android:padding="20dp"
        android:elevation="2dp"
        android:layout_marginHorizontal="40dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintTop_toBottomOf="@+id/subtitleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/buttonContainer">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="참가자 정보"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="참가자 이름 또는 번호를 입력해주세요"
            android:textSize="16sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/participantNameEditText"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="예: 홍길동, P001, 참가자1"
            android:textSize="18sp"
            android:textAlignment="center"
            android:background="@drawable/edittext_background"
            android:padding="16dp"
            android:maxLines="1"
            android:inputType="text" />

    </LinearLayout>
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/subtitleText">

        <!-- 사용법 버튼 -->
        <Button
            android:id="@+id/manualButton"
            android:layout_width="280dp"
            android:layout_height="60dp"
            android:text="실험 사용법"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:background="@drawable/button_manual"
            android:elevation="4dp"
            android:layout_marginBottom="16dp" />

        <!-- 실험 시작 버튼 -->
        <Button
            android:id="@+id/startButton"
            android:layout_width="280dp"
            android:layout_height="60dp"
            android:text="실험 시작"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:background="@drawable/button_start"
            android:elevation="4dp" />

    </LinearLayout>

    <!-- 하단 안내 텍스트 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="실험 전 반드시 사용법을 확인해주세요"
        android:textSize="14sp"
        android:textColor="#999999"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>