<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- 헤더 영역 -->
    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:background="@drawable/manual_header_background"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:elevation="6dp">

        <!-- 뒤로가기 버튼 -->
        <Button
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="◀ 뒤로"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/back_button"
            android:padding="16dp" />

        <!-- 제목 -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="N-Back 실험 매뉴얼"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center" />

        <!-- 공간 확보용 뷰 -->
        <View
            android:layout_width="80dp"
            android:layout_height="48dp" />

    </LinearLayout>

    <!-- 매뉴얼 내용 스크롤 영역 -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@id/headerContainer"
        android:layout_above="@id/startButton"
        android:background="@drawable/manual_content_background"
        android:layout_margin="16dp"
        android:padding="20dp"
        android:elevation="4dp">

        <!-- 매뉴얼 텍스트 -->
        <TextView
            android:id="@+id/manualText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="매뉴얼 내용이 여기에 표시됩니다."
            android:textSize="16sp"
            android:textColor="#2C3E50"
            android:lineSpacingMultiplier="1.4"
            android:paddingBottom="32dp"
            android:fontFamily="monospace" />

    </ScrollView>

    <!-- 실험 시작 버튼 -->
    <Button
        android:id="@+id/startButton"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        android:text="실험 시작"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/manual_start_button"
        android:layout_margin="16dp"
        android:elevation="8dp" />

</RelativeLayout>

