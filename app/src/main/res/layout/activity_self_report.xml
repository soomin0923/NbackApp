<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f8f9fa">

    <!-- 상단 제목 바 -->
    <LinearLayout
        android:id="@+id/titleBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#1B8A85"
        android:orientation="vertical"
        android:padding="20dp"
        android:elevation="4dp"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="현재 기분 설문"
            android:textColor="#ffffff"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:accessibilityHeading="true"/>

        <TextView
            android:id="@+id/blockInfoText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="지금 이 순간 느끼는 감정과 상태에 대해\n솔직하게 답해주세요."
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:gravity="center" />

    </LinearLayout>

    <!-- 스크롤 가능한 설문 내용 -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:fillViewport="true"
        android:importantForAccessibility="no"
        android:contentDescription="@null"
        android:focusable="false"
        android:clickable="false"
        android:descendantFocusability="afterDescendants"
        app:layout_constraintTop_toBottomOf="@id/titleBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/submitButton">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:elevation="2dp"
            android:padding="24dp">

            <!-- 안내문구 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="다음 문장들을 읽고, 지금 이 순간 자신의 감정과 가장 일치하는 정도를 선택해주세요."
                android:textSize="16sp"
                android:textColor="#666666"
                android:layout_marginBottom="24dp"
                android:lineSpacingExtra="4dp" />

            <!-- 질문 1: 차분함 (역문항) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. 나는 차분하다"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"
                android:labelFor="@id/calmRadioGroup"/>


            <RadioGroup
                android:id="@+id/calmRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/calm1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="1. 전혀 그렇지 않다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/calm2"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="2. 조금 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/calm3"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="3. 어느 정도 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/calm4"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="4. 매우 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#e0e0e0"
                android:layout_marginVertical="20dp" />

            <!-- 질문 2: 긴장감 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. 나는 긴장되어 있다"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"
                android:labelFor="@id/tensionRadioGroup"/>

            <RadioGroup
                android:id="@+id/tensionRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/tension1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="1. 전혀 그렇지 않다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/tension2"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="2. 조금 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/tension3"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="3. 어느 정도 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/tension4"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="4. 매우 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#e0e0e0"
                android:layout_marginVertical="20dp" />

            <!-- 질문 3: 편안함 (역문항) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. 나는 편안하다"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"
                android:labelFor="@id/relaxedRadioGroup"/>

            <RadioGroup
                android:id="@+id/relaxedRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/relaxed1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="1. 전혀 그렇지 않다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/relaxed2"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="2. 조금 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/relaxed3"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="3. 어느 정도 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/relaxed4"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="4. 매우 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#e0e0e0"
                android:layout_marginVertical="20dp" />

            <!-- 질문 4: 걱정 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4. 나는 걱정스럽다"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"
                android:labelFor="@id/worriedRadioGroup"/>

            <RadioGroup
                android:id="@+id/worriedRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/worried1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="1. 전혀 그렇지 않다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/worried2"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="2. 조금 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/worried3"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="3. 어느 정도 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/worried4"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="4. 매우 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#e0e0e0"
                android:layout_marginVertical="20dp" />

            <!-- 질문 5: 만족감 (역문항) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="5. 나는 만족스럽다"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"
                android:labelFor="@id/satisfiedRadioGroup"/>

            <RadioGroup
                android:id="@+id/satisfiedRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/satisfied1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="1. 전혀 그렇지 않다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/satisfied2"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="2. 조금 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/satisfied3"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="3. 어느 정도 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/satisfied4"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="4. 매우 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#e0e0e0"
                android:layout_marginVertical="20dp" />

            <!-- 질문 6: 두려움 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="6. 나는 불안하다"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"
                android:labelFor="@id/anxiousRadioGroup"/>

            <RadioGroup
                android:id="@+id/anxiousRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/anxious1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="1. 전혀 그렇지 않다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/anxious2"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="2. 조금 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/anxious3"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="3. 어느 정도 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <RadioButton
                    android:id="@+id/anxious4"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="4. 매우 그렇다"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </RadioGroup>

        </LinearLayout>

    </ScrollView>

    <!-- 제출 버튼 -->
    <Button
        android:id="@+id/submitButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        android:text="설문 완료"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#ffffff"
        android:background="#1B8A85"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>