<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f5f5"
    android:padding="16dp">

    <!-- 상단 지시문 -->

    <!-- 타이머 (상단 오른쪽) -->

    <!-- 진행률 (상단 왼쪽) -->


    <TextView
        android:id="@+id/instructionText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="#ffffff"
        android:elevation="2dp"
        android:gravity="center"
        android:padding="16dp"
        android:text="현재 난이도: N-back\nN 번째 이전 숫자를 작성"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="1.0" />

    <!-- 자극 숫자 표시 (중앙 상단) -->

    <!-- 손글씨 입력 캔버스 -->

    <!-- 하단 버튼들 -->

    <TextView
        android:id="@+id/progressText"
        android:layout_width="380dp"
        android:layout_height="79dp"
        android:layout_marginTop="16dp"
        android:background="#f5f5f5"
        android:elevation="3dp"
        android:padding="12dp"
        android:text="시행: 0 / 30"
        android:textColor="#000000"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/stimulusText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/instructionText"
        app:layout_constraintVertical_bias="0.776" />

    <TextView
        android:id="@+id/stimulusText"
        android:layout_width="328dp"
        android:layout_height="181dp"
        android:background="#f5f5f5"
        android:gravity="center"
        android:text="30"
        android:textColor="#000000"
        android:textSize="72sp"
        android:textStyle="bold"
        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@+id/canvasFrame"
        app:layout_constraintEnd_toEndOf="@+id/canvasFrame"
        app:layout_constraintHorizontal_bias="0.441"
        app:layout_constraintStart_toStartOf="@+id/canvasFrame"
        app:layout_constraintTop_toBottomOf="@+id/instructionText"
        app:layout_constraintVertical_bias="0.024" />

    <FrameLayout
        android:id="@+id/canvasFrame"
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_marginStart="300dp"
        android:layout_marginEnd="300dp"
        android:background="#ffffff"
        android:elevation="2dp"
        android:padding="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- 캔버스 안내 텍스트 -->

        <TextView
            android:id="@+id/canvasHintText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:alpha="0.7"
            android:text="여기에 S Pen으로 숫자를 써주세요"
            android:textColor="#cccccc"
            android:textSize="18sp" />

        <com.example.nback.DrawingView
            android:id="@+id/drawingView"
            android:layout_width="400dp"
            android:layout_height="400dp"
            android:background="#ffffff" />

    </FrameLayout>


    <LinearLayout
        android:id="@+id/buttonLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

    </LinearLayout>

    <!-- 실험 시작/튜토리얼 건너뛰기 버튼 (가운데 정렬, 위아래 배치) -->

    <TextView
        android:id="@+id/timerText"
        android:layout_width="413dp"
        android:layout_height="89dp"
        android:layout_marginTop="84dp"
        android:background="#333333"
        android:elevation="3dp"
        android:padding="12dp"
        android:text="타이머"
        android:textColor="#ffffff"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/skipTutorialButton"
        app:layout_constraintEnd_toStartOf="@+id/stimulusText"
        app:layout_constraintHorizontal_bias="0.304"
        app:layout_constraintStart_toStartOf="@+id/instructionText"
        app:layout_constraintTop_toBottomOf="@+id/instructionText" />

    <Button
        android:id="@+id/startButton"
        android:layout_width="179dp"
        android:layout_height="60dp"
        android:background="#000000"
        android:text="실험 시작"
        android:textColor="#ffffff"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/canvasFrame"
        app:layout_constraintEnd_toEndOf="@+id/canvasFrame"
        app:layout_constraintHorizontal_bias="0.427"
        app:layout_constraintStart_toStartOf="@+id/stimulusText"
        app:layout_constraintTop_toBottomOf="@+id/stimulusText"
        app:layout_constraintVertical_bias="0.592" />

    <Button
        android:id="@+id/skipTutorialButton"
        android:layout_width="179dp"
        android:layout_height="50dp"
        android:layout_marginTop="4dp"
        android:background="#dddddd"
        android:text="튜토리얼 건너뛰기"
        android:visibility="invisible"
        android:textColor="#222222"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.083"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/startButton" />

    <Button
        android:id="@+id/clearButton"
        android:layout_width="104dp"
        android:layout_height="60dp"
        android:background="#ff6b6b"
        android:text="지우기"
        android:textColor="#ffffff"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="@+id/canvasFrame"
        app:layout_constraintEnd_toEndOf="@+id/progressText"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@+id/canvasFrame"
        app:layout_constraintTop_toBottomOf="@+id/progressText"
        app:layout_constraintVertical_bias="0.059" />


</androidx.constraintlayout.widget.ConstraintLayout>