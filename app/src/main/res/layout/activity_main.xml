<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- 긴급 버튼 (우상단) -->
    <Button
        android:id="@+id/emergencyButton"
        android:layout_width="80dp"
        android:layout_height="48dp"
        android:text="긴급"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/emergency_button"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"
        android:layout_margin="12dp"
        android:elevation="8dp" />

    <!-- 상단 정보 영역 -->
    <LinearLayout
        android:id="@+id/topInfoContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/emergencyButton"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/info_card_background">

        <!-- 지시사항 텍스트 -->
        <TextView
            android:id="@+id/instructionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="현재 난이도: 0-back\n현재 화면에 표시되는 숫자를 써주세요"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="12dp" />

        <!-- 진행상황 텍스트 -->
        <TextView
            android:id="@+id/progressText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="시행: 0 / 30 (블록 1/7)"
            android:textSize="16sp"
            android:textColor="#7F8C8D"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- 타이머 텍스트 -->
        <TextView
            android:id="@+id/timerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="실험을 시작하세요"
            android:textSize="16sp"
            android:textColor="#E74C3C"
            android:textStyle="bold"
            android:gravity="center" />

    </LinearLayout>

    <!-- 자극 제시 영역 (중앙 상단) -->
    <RelativeLayout
        android:id="@+id/stimulusContainer"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_below="@id/topInfoContainer"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:background="@drawable/stimulus_background">

        <TextView
            android:id="@+id/stimulusText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="7"
            android:textSize="120sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"
            android:gravity="center"
            android:visibility="invisible" />

    </RelativeLayout>

    <!-- 그리기 영역 -->
    <RelativeLayout
        android:id="@+id/drawingContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@id/stimulusContainer"
        android:layout_above="@id/controlButtonsContainer"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="16dp">

        <!-- 그리기 뷰 -->
        <com.example.nback.DrawingView
            android:id="@+id/drawingView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:elevation="4dp" />

        <!-- 캔버스 힌트 텍스트 -->
        <TextView
            android:id="@+id/canvasHintText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="여기에 숫자를 써주세요"
            android:textSize="18sp"
            android:textColor="#BDC3C7"
            android:layout_centerInParent="true"
            android:visibility="visible" />

    </RelativeLayout>

    <!-- 컨트롤 버튼 영역 (하단) -->
    <LinearLayout
        android:id="@+id/controlButtonsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_above="@id/restartAppButton"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center">

        <!-- 지우기 버튼 -->
        <Button
            android:id="@+id/clearButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="지우기"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/clear_button"
            android:layout_marginRight="12dp"
            android:elevation="4dp" />

        <!-- 시작 버튼 -->
        <Button
            android:id="@+id/startButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="2"
            android:text="실험 시작"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/start_button"
            android:elevation="4dp" />

    </LinearLayout>

    <!-- 앱 재시작 버튼 (실험 완료 후 표시) -->
    <Button
        android:id="@+id/restartAppButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="새 참가자를 위한 앱 재시작"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/restart_button"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:elevation="6dp"
        android:visibility="gone" />

</RelativeLayout>

